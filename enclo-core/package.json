{
  "name": "@enclo/core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared core for the enclo CLI and editor extensions: API client, agent loop, tool registry, MCP, hooks, permissions, custom commands.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ky": "^1.7.2",
    "turndown": "^7.2.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
